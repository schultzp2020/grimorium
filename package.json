{
  "name": "grimorium",
  "version": "0.1.0",
  "private": true,
  "description": "A companion app for Blood on the Clocktower that handles the clockwork so you can focus on the story.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsgo -b && vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "tsc": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware --type-check .",
    "lint:fix": "oxlint --type-aware --type-check --fix .",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:android-dev": "tauri android dev",
    "tauri:android-build": "tauri android build"
  },
  "dependencies": {
    "@lucide/lab": "^0.1.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "@tanstack/react-router": "^1.168.10",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@use-gesture/react": "^10.3.1",
    "@xstate/react": "^6.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.1",
    "xstate": "^5.30.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@playwright/test": "^1.59.1",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-plugin": "^1.167.12",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260407.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.0.2",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.20.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.6",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.3"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  },
  "engines": {
    "node": ">=22"
  }
}
