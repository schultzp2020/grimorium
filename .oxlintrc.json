{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "oxc",
    "react",
    "react-perf",
    "import",
    "jsx-a11y",
    "node",
    "promise",
    "vitest"
  ],
  "rules": {
    "react/react-in-jsx-scope": "off"
  },
  "ignorePatterns": ["**/node_modules", "**/dist", "**/public"]
}
